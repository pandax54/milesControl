# ═══════════════════════════════════════════════════════════════════
#  .env.example — Environment variables for workflow automation
# ═══════════════════════════════════════════════════════════════════
# Copy to .env and fill in your values:
#   cp .env.example .env

# ─── Jira ────────────────────────────────────────────────────────
# Your Atlassian instance URL (no trailing slash)
JIRA_BASE_URL=https://strvcom.atlassian.net
# Your Atlassian account email
JIRA_USER_EMAIL=your.email@strv.com
# API token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=
# Project key (the prefix of your issue IDs, e.g. LD for LD-14)
JIRA_PROJECT=LD

# ─── Telegram ───────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# Your chat/group ID (send /start to @userinfobot to find it)
TELEGRAM_CHAT_ID=

# ─── Git ─────────────────────────────────────────────────────────
# Remote name (default: origin)
GITHUB_REMOTE=origin
# Base branch for new feature branches (default: main)
BASE_BRANCH=main
# Path to the project repository (if scripts are in a separate folder)
# PROJECT_REPO=/path/to/your/project
